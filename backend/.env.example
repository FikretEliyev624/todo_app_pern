PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Postgres (Prisma) ---
# Supabase exposes two connection strings — use BOTH:
#   DATABASE_URL = transaction-mode pooler (port 6543, pgbouncer=true) for app queries
#   DIRECT_URL   = session-mode pooler     (port 5432)                  for migrations
# Replace [YOUR-PASSWORD] with the DB password from
#   Supabase Dashboard → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.xmqupxwbcareuhaklali:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xmqupxwbcareuhaklali:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Local Postgres (Docker) example — uncomment to use instead:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/notepad_todo?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/notepad_todo?schema=public"

# --- Auth ---
# Long random string (e.g. `node -e "console.log(crypto.randomBytes(48).toString('hex'))"`)
JWT_SECRET="change-me-to-a-long-random-string"
JWT_TTL="7d"
